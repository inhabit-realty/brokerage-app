# Listing Data API
# Generate a key at https://app.listingdata.com → "API Key" in the sidebar.
# The raw `ld_live_…` value is shown only once; copy it here. Never commit.
LISTING_DATA_API_KEY=ld_live_replace_me

# Base URL for the Listing Data API.
# Defaults to the AWS staging URL documented in the Listing Data project.
# When dev.listingdata.com is set up as a custom domain, change to https://dev.listingdata.com.
LISTING_DATA_BASE_URL=https://djf94h8g1l.execute-api.us-east-1.amazonaws.com/staging

